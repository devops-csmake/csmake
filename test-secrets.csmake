[metadata@secrets-testing]
name=secrets-testing
version=0.0.0
description=Testing secrets module and (((key))) substitution
about=Testing

### Provider sections

[secrets@plaintext]
source=test-secrets/plaintext.json

[secrets@named]
source=test-secrets/plaintext.json
namespace=myns

[secrets@first]
source=test-secrets/first.json

[secrets@second]
source=test-secrets/second.json

[secrets@obfuscated-creds]
source=test-secrets/test.obf
unlock=CSMAKE_TEST_OBF_CRED
obfuscate=yes

### Shell steps

[Shell@echo-db-pass]
command=echo (((db_pass)))

[Shell@echo-colon-default]
command=echo (((:db_pass)))

[Shell@echo-named]
command=echo (((myns:db_pass)))

[Shell@echo-embedded]
command=echo prefix-(((db_pass)))-suffix

[Shell@echo-overwritten]
command=echo (((shared_key)))

[Shell@echo-union-adds]
command=echo (((first_only)))-(((second_only)))

[Shell@echo-obf-key]
command=echo (((obf_key)))

[Shell@echo-missing-key]
command=echo (((no_such_key)))

[Shell@echo-missing-ns]
command=echo (((badns:db_pass)))

### Test commands

[command@default-namespace]
description=Plaintext secrets in default namespace
00=plaintext, echo-db-pass

[command@colon-default]
description=Colon-prefix form addresses the default namespace identically to no-prefix form
00=plaintext, echo-colon-default

[command@named-namespace]
description=Secrets in a named namespace, referenced with explicit namespace prefix
00=named, echo-named

[command@embedded]
description=Secret embedded in a larger string resolves to plain value
00=plaintext, echo-embedded

[command@union-overwrites]
description=Two providers in the same namespace - later registration wins on key collision
00=first, second, echo-overwritten

[command@union-adds]
description=Two providers in the same namespace each contribute distinct keys
00=first, second, echo-union-adds

[command@obfuscated]
description=Obfuscated provider - HMAC-XOR file unlocked via env var
00=obfuscated-creds, echo-obf-key

[command@missing-key]
description=Referencing an undefined secret key should fail the step
00=plaintext, echo-missing-key

[command@missing-namespace]
description=Referencing an unregistered namespace should fail the step
00=plaintext, echo-missing-ns
